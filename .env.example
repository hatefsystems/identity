# Hatef Identity Platform - local development environment template.
#
# Copy this file to `.env` (which is gitignored) and adjust as needed:
#   cp .env.example .env
#
# These values feed docker-compose.dev.yml and the Go identity-api service for
# LOCAL DEVELOPMENT ONLY. Never commit real secrets. In staging/production,
# secrets are injected at runtime by the KMS/secrets manager (Infisical) per
# the DevOps playbook and Definition of Done #3.

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=identity
POSTGRES_PASSWORD=identity_dev_password
POSTGRES_DB=identity
POSTGRES_PORT=5432
# Connection string the Go backend can consume (pgx / sqlc).
DATABASE_URL=postgres://identity:identity_dev_password@127.0.0.1:5432/identity?sslmode=disable

# --- Redis ------------------------------------------------------------------
# Leave REDIS_PASSWORD empty to run Redis without auth locally, or set a value
# to enable --requirepass (the compose healthcheck adapts automatically).
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# --- NATS JetStream ---------------------------------------------------------
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_URL=nats://127.0.0.1:4222

# --- Application-Layer Envelope Encryption (Task 2.3) -----------------------
# LOCAL DEVELOPMENT ONLY. In staging/production these are injected at runtime
# by the KMS/secrets manager (Infisical) per docs/devops-operations.md §2.1.
# NEVER commit real key material. Regenerate your own local values, e.g.:
#   openssl rand -base64 32
#
# Master Key Encryption Key (KEK): base64-encoded, must decode to exactly 32
# bytes (AES-256). Wraps the per-record Data Encryption Keys (DEKs).
ENVELOPE_MASTER_KEK=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# Version byte stamped into every envelope blob (0-255) for KEK rotation.
ENVELOPE_MASTER_KEK_VERSION=1
# Secret pepper for the SHA-256 blind index: base64-encoded, >=32 bytes.
ENVELOPE_BLIND_INDEX_PEPPER=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- OIDC / OAuth2 Signing Keys (Task 3.1) ----------------------------------
# The issuer is the canonical URL identifying this IdP; it is embedded in the
# discovery document (/.well-known/openid-configuration) and all issued tokens.
# In development it defaults to http://localhost:8080 when unset; outside
# development it is REQUIRED and must be an https URL.
OIDC_ISSUER=http://localhost:8080
#
# Signing keys back the graceful 3-key JWKS rotation cycle (active/next/previous)
# served at /oauth2/jwks. Provide PEM-encoded PRIVATE keys, RS256 (>=2048-bit
# RSA) or ES256 (NIST P-256) only — symmetric algorithms are prohibited.
#
# LOCAL DEVELOPMENT ONLY: if these are left empty in the development environment
# the server generates ephemeral ES256 keys at startup (process-local, never
# persisted). Outside development, OIDC_SIGNING_KEY_ACTIVE_PEM and
# OIDC_SIGNING_KEY_NEXT_PEM are REQUIRED and injected by the KMS (Infisical).
# The PREVIOUS slot is optional (empty on a fresh deployment). Generate a local
# ES256 key with:
#   openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt
# Multi-line PEM values must be provided as-is (e.g. via docker/compose env files
# or the KMS); shell `.env` files do not support raw newlines in a value.
OIDC_SIGNING_KEY_ACTIVE_PEM=
OIDC_SIGNING_KEY_NEXT_PEM=
OIDC_SIGNING_KEY_PREVIOUS_PEM=

# --- OIDC Client Registry (Task 3.2) ----------------------------------------
# Clients are registered via static config / IaC only — there is no public
# developer portal (docs/architecture.md "Secure Client Authentication"). The
# authorization endpoint (/oauth2/auth) resolves the client_id, exact-matches
# the redirect_uri, and enforces the client's allowed scopes from this list.
#
# JSON array of client definitions. Each entry:
#   client_id                   : unique client identifier
#   redirect_uris               : exact-match allow-list (no wildcards/prefixes)
#   token_endpoint_auth_method  : "none" (public) or "private_key_jwt" (confidential)
#   allowed_scopes              : scopes the client may request (must include "openid")
#   jwks                        : REQUIRED for private_key_jwt clients — a JWK Set
#                                 ({"keys":[...]}) of the client's PUBLIC verification
#                                 keys (RS256 >=2048-bit RSA or ES256 P-256 only).
#                                 MUST be omitted/empty for "none" (public) clients.
#
# Confidential internal services (Search Engine, Email Service) authenticate to
# /oauth2/token via RFC 7523 private_key_jwt (Task 3.4): they present a short-lived
# JWT assertion signed with their PRIVATE key, verified here against the PUBLIC
# keys in "jwks". No shared secrets are ever stored (docs/architecture.md
# "Secure Client Authentication"). Generate a client key pair, then publish only
# the public JWK here; the private key lives with the client (injected by the KMS).
#
# LOCAL DEVELOPMENT ONLY: when unset in the development environment, a single
# public client "hatef-nextjs-app" is seeded automatically. Outside development
# this variable is REQUIRED and injected by the KMS (Infisical).
# Examples:
#   Public (PKCE) client:
#     OIDC_CLIENTS_JSON=[{"client_id":"hatef-nextjs-app","redirect_uris":["https://hatef.ir/callback"],"token_endpoint_auth_method":"none","allowed_scopes":["openid","profile","email","offline_access"]}]
#   Confidential (private_key_jwt) client — note the embedded public "jwks":
#     OIDC_CLIENTS_JSON=[{"client_id":"search-core","redirect_uris":["https://search.hatef.ir/callback"],"token_endpoint_auth_method":"private_key_jwt","allowed_scopes":["openid","search.full"],"jwks":{"keys":[{"kty":"EC","crv":"P-256","kid":"search-core-2026","x":"f83OJ3D2xF1Bg8vub9tLe1gHMzV76e8Tus9uPHvRVEU","y":"x_FEzRu9m36HLN_tue659LNpXW6pCyStikYjKIWI5a0"}]}}]
OIDC_CLIENTS_JSON=


