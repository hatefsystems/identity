{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "identity-api",
  "projectType": "application",
  "sourceRoot": "apps/identity-api",
  "tags": ["lang:go", "scope:backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/identity-api",
        "command": "go build -o bin/identity-api ./cmd/server"
      },
      "cache": true
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/identity-api",
        "command": "go run ./cmd/server"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/identity-api",
        "command": "go test ./..."
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/identity-api",
        "command": "golangci-lint run ./..."
      },
      "cache": true
    },
    "vet": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/identity-api",
        "command": "go vet ./..."
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/identity-api",
        "command": "go mod tidy"
      }
    }
  }
}
